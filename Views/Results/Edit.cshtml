@model CollegeCost

@{
    ViewData["Title"] = "Tuition Calculator - Edit";
}

<div class="border rounded bg-info">

    @* define a form that the user can provide input to be submitted for processing *@
    @* use "row" and "col" bootstrap classes as needed to provide responsive web design support + margin-bottom spacing of 3px to separate each row*@
    <form asp-controller="Results" asp-action="Save" method="post">@* uses a tag helper so results of the form are posted to the ResultsController for processing*@
        <div class="row m-1 text-center">
            <h1 class="col">@ViewBag.Title</h1>
        </div>
        <div class="row m-1">
            @* define a label and input element using asp-for tag helpers to bind their value to that appropriate property of the model class *@
            <div class="col-3">
                <label asp-for="CostPerCreditHour" class="form-label">Cost per credit hour</label>
            </div>
            <div class="col-4">
                <input asp-for="CostPerCreditHour" class="form-control" />@* applies bootstrap class for styling *@
            </div>
            <div class="col">
                <span asp-validation-for="CostPerCreditHour" class="text-danger"></span>
            </div>
        </div>
        <div class="row m-1">
            <div class="col-3">
                <label asp-for="Timeframe" class="form-label">Timeframe</label>
            </div>
            <div class="col-4">
                <select asp-for="Timeframe" class="form-select col-6">
                    <option value="">Please make a selection...</option>
                    <option>Quarter</option>
                    <option>Semester</option>
                    <option>Year</option>
                </select>
            </div>
            <div class="col">
                <span asp-validation-for="Timeframe" class="text-danger"></span>
            </div>
        </div>
        <div class="row m-1">
            <div class="col-3">
                <label asp-for="CreditHoursPerTerm" class="form-label">Credit hours per term</label>
            </div>
            <div class="col-4">
                <input asp-for="CreditHoursPerTerm" class="form-control" type="text" />
            </div>
            <div class="col">
                <span asp-validation-for="CreditHoursPerTerm" class="text-danger"></span>
            </div>
        </div>
        <div class="row m-1">
            <div class="col-3">
                <label asp-for="CostOfHousing" class="form-label">Cost of housing</label>
            </div>
            <div class="col-4">
                <input asp-for="CostOfHousing" class="form-control" />
            </div>
            <div class="col">
                <span asp-validation-for="CostOfHousing" class="text-danger"></span>
            </div>
        </div>
        <div class="row m-1">
            <div class="col-3">
                <label asp-for="CostOfBooks" class="form-label">Cost of books</label>
            </div>
            <div class="col-4">
                <input asp-for="CostOfBooks" class="form-control" />
            </div>
            <div class="col">
                <span asp-validation-for="CostOfBooks" class="text-danger"></span>
            </div>
        </div>
        <div class="row m-1">
            <div class="col-3">
                <label asp-for="YearsToGraduate" class="form-label">Years to graduate</label>
            </div>
            <div class="col-4">
                <input asp-for="YearsToGraduate" class="form-control" type="text" />
            </div>
            <div class="col">
                <span asp-validation-for="YearsToGraduate" class="text-danger"></span>
            </div>
        </div>

        @* add hidden fields to pass all other properties of the model upon submission *@
        @Html.HiddenFor(m => m.CollegeCostId)
        @Html.HiddenFor(m => m.TotalCreditHours)
        @Html.HiddenFor(m => m.AverageHousingPerYear)
        @Html.HiddenFor(m => m.AverageBooksPerYear)
        @Html.HiddenFor(m => m.AverageTuitionPerYear)

        @* define a button that submits user's entered data for calculation to the controller*@
        @* also includes a link to access the database interface*@
        <div class="row m-1">
            <button type="submit" class="btn btn-primary col-mde-3 col-6 m-3">Save Changes</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-danger col-md-3 col-6 m-3">Cancel</a>
        </div>
    </form>
</div>